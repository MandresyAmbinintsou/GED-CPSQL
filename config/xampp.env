# Configuration pour XAMPP (Windows)
# Placez ces variables dans un fichier .env ou configurez-les dans votre environnement

# Base de données MySQL (XAMPP)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=archives_db
DB_USER=root
DB_PASS=

# Pour PostgreSQL (si vous préférez)
# DB_TYPE=pgsql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=archives_db
# DB_USER=postgres
# DB_PASS=postgres

# Chemin des archives (adaptez selon votre configuration)
# ARCHIVES_PATH=C:\Users\VotreNom\Documents\Archives